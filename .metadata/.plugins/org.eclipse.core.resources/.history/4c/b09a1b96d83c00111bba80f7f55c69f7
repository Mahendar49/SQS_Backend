package com.smartqueue.gateway.config;

import org.springframework.stereotype.Component;

import java.util.*;

@Component
public class RouteSecurityConfig {

    /**
     * Public APIs (no auth required)
     */
    private static final List<String> PUBLIC_ENDPOINTS = List.of(
            "/api/v1/auth/**"
    );

    /**
     * Role-based access rules
     */
    private static final Map<String, List<String>> ROLE_BASED_RULES = Map.of(
            "/api/v1/business/**", List.of("ADMIN"),
            "/api/v1/queue/**", List.of("USER", "ADMIN")
    );

    public boolean isPublic(String path) {
        return PUBLIC_ENDPOINTS.stream().anyMatch(path::startsWith);
    }

    public Optional<List<String>> getAllowedRoles(String path) {
        return ROLE_BASED_RULES.entrySet().stream()
                .filter(entry -> path.startsWith(entry.getKey().replace("/**", "")))
                .map(Map.Entry::getValue)
                .findFirst();
    }
}