package com.smartqueue.gateway.util;

import io.jsonwebtoken.Claims;
import io.jsonwebtoken.Jwts;
import io.jsonwebtoken.security.Keys;
import org.springframework.beans.factory.annotation.Value;
import org.springframework.stereotype.Component;

import java.security.Key;

/**
 * Purpose:
 * Handles JWT validation and claim extraction in API Gateway
 *
 * Responsibilities:
 * - Validate token signature & expiry
 * - Extract claims (userId, roles, permissions)
 *
 * NOTE:
 * - Gateway should NOT return boolean
 * - Always return Claims (single parsing)
 */
@Component
public class JwtUtil {

    @Value("${jwt.secret}")
    private String secret;

    private Key getKey() {
        return Keys.hmacShaKeyFor(secret.getBytes());
    }

    /**
     * Validate and return claims
     */
    public Claims validateAndExtract(String token) {

        return Jwts.parserBuilder()
                .setSigningKey(getKey())
                .build()
                .parseClaimsJws(token)
                .getBody();
    }
}