package com.smartqueue.gateway.config;

import com.smartqueue.gateway.filter.JwtAuthWebFilter;
import org.springframework.cloud.gateway.route.RouteLocator;
import org.springframework.cloud.gateway.route.builder.RouteLocatorBuilder;
import org.springframework.context.annotation.Bean;
import org.springframework.context.annotation.Configuration;

/**
 * Purpose:
 * Central routing configuration for API Gateway
 *
 * Responsibilities:
 * - Route requests to respective microservices
 * - Apply JWT filter for secured routes
 */
@Configuration
public class GatewayConfig {

    private final JwtAuthWebFilter jwtFilter;

    public GatewayConfig(JwtAuthWebFilter jwtFilter) {
        this.jwtFilter = jwtFilter;
    }

    @Bean
    public RouteLocator customRoutes(RouteLocatorBuilder builder) {

        return builder.routes()

                // 🔓 AUTH SERVICE (PUBLIC - NO JWT)
                .route("auth-service", r -> r
                        .path("/api/v1/auth/**")
                        .uri("http://localhost:8081"))

                // 🔐 BUSINESS SERVICE (SECURED)
                .route("business-service", r -> r
                        .path("/api/v1/business/**")
                        .filters(f -> f.filter(jwtFilter))
                        .uri("http://localhost:8082"))

                // 🔐 QUEUE SERVICE (SECURED)
                .route("queue-service", r -> r
                        .path("/api/v1/queue/**")
                        .filters(f -> f.filter(jwtFilter))
                        .uri("http://localhost:8083"))

                .build();
    }
}