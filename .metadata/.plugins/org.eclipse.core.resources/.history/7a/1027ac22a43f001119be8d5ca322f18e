package com.smartqueue.business.controller;

import java.util.List;

import org.springframework.web.bind.annotation.DeleteMapping;
import org.springframework.web.bind.annotation.GetMapping;
import org.springframework.web.bind.annotation.PathVariable;
import org.springframework.web.bind.annotation.PostMapping;
import org.springframework.web.bind.annotation.RequestBody;
import org.springframework.web.bind.annotation.RequestHeader;
import org.springframework.web.bind.annotation.RequestMapping;
import org.springframework.web.bind.annotation.RestController;

import com.smartqueue.business.dto.ApiResponse;
import com.smartqueue.business.dto.BusinessResponse;
import com.smartqueue.business.dto.CounterRequest;
import com.smartqueue.business.dto.CounterResponse;
import com.smartqueue.business.dto.CreateBusinessRequest;
import com.smartqueue.business.dto.QueueRequest;
import com.smartqueue.business.dto.QueueResponse;
import com.smartqueue.business.service.BusinessService;

import jakarta.validation.Valid;

@RestController
@RequestMapping("/api/v1/business")
public class BusinessController {

    private final BusinessService service;

    public BusinessController(BusinessService service) {
        this.service = service;
    }

    // ================= BUSINESS =================

    @PostMapping
    public ApiResponse<BusinessResponse> createBusiness(
            @Valid @RequestBody CreateBusinessRequest request,
            @RequestHeader("X-User-Id") String userId) {

        return new ApiResponse<>(
                true,
                "Business created successfully",
                service.createBusiness(request, userId)
        );
    }

    @GetMapping("/{id}")
    public ApiResponse<BusinessResponse> getBusiness(
            @PathVariable Long id,
            @RequestHeader("X-User-Id") String userId) {

        return new ApiResponse<>(
                true,
                "Business fetched",
                service.getBusinessResponse(id, userId)
        );
    }

    @GetMapping("/all")
    public ApiResponse<List<BusinessResponse>> getAllBusinesses() {

        return new ApiResponse<>(
                true,
                "Businesses fetched",
                service.getAllBusinesses()
        );
    }
    // ================= COUNTER =================

    @PostMapping("/{id}/counter")
    public ApiResponse<String> addCounter(
            @PathVariable Long id,
            @Valid @RequestBody CounterRequest request,
            @RequestHeader("X-User-Id") String userId) {

        service.addCounter(id, request, userId);

        return new ApiResponse<>(true, "Counter added successfully", null);
    }

//    @GetMapping("/{id}/counters")
//    public ApiResponse<List<CounterResponse>> getCounters(
//            @PathVariable Long id,
//            @RequestHeader("X-User-Id") String userId) {
//
//        return new ApiResponse<>(
//                true,
//                "Counters fetched",
//                service.getCounters(id, userId)
//        );
//    }
    @GetMapping("/{id}/counters")
    public ApiResponse<List<CounterResponse>> getCounters(
            @PathVariable Long id) {

        return new ApiResponse<>(
                true,
                "Counters fetched",
                service.getCountersForUser(id)
        );
    }

    // ================= QUEUE =================

    @PostMapping("/{businessId}/counter/{counterId}/queue")
    public ApiResponse<String> createQueue(
            @PathVariable Long businessId,
            @PathVariable Long counterId,
            @Valid @RequestBody QueueRequest request,
            @RequestHeader("X-User-Id") String userId) {

        service.createQueue(businessId, counterId, request, userId);

        return new ApiResponse<>(true, "Queue created successfully", null);
    }

