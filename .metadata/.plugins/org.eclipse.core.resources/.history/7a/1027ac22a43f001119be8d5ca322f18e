    @GetMapping("/{businessId}/queues")
    public ApiResponse<List<QueueResponse>> getQueues(
            @PathVariable Long businessId) {

        return new ApiResponse<>(
                true,
                "Queues fetched",
                service.getQueuesForUser(businessId)
        );
    }

    @GetMapping("/{businessId}/counter/{counterId}/queues")
    public ApiResponse<List<QueueResponse>> getQueuesByCounter(
            @PathVariable Long businessId,
            @PathVariable Long counterId,
            @RequestHeader("X-User-Id") String userId) {

        return new ApiResponse<>(
                true,
                "Queues fetched",
                service.getQueuesByCounter(businessId, counterId, userId)
        );
    }

    @DeleteMapping("/{businessId}/queue/{queueId}")
    public ApiResponse<String> deleteQueue(
            @PathVariable Long businessId,
            @PathVariable Long queueId,
            @RequestHeader("X-User-Id") String userId) {

        service.deleteQueue(businessId, queueId, userId);

        return new ApiResponse<>(true, "Queue deleted successfully", null);
    }
}