package com.smartqueue.queue.controller;

import java.util.List;

import org.springframework.web.bind.annotation.*;

import com.smartqueue.queue.dto.*;
import com.smartqueue.queue.entity.Notification;
import com.smartqueue.queue.entity.PriorityType;
import com.smartqueue.queue.service.NotificationService;
import com.smartqueue.queue.service.QueueService;

import jakarta.validation.Valid;

@RestController
@RequestMapping("/api/v1/queue")
public class QueueController {

    private final QueueService service;
    private final NotificationService notificationService;

    public QueueController(QueueService service,
                           NotificationService notificationService) {
        this.service = service;
        this.notificationService = notificationService;
    }

    // ================= JOIN =================

    @PostMapping("/join")
    public ApiResponse<JoinQueueResponse> join(
            @RequestHeader("X-User-Id") Long userId,
            @RequestParam Long queueId,
            @RequestParam(defaultValue = "NORMAL") PriorityType priority) {

        return new ApiResponse<>(
                true,
                "Join request processed",
                service.joinQueue(userId, queueId, priority)
        );
    }

    // ================= CANCEL =================

    @PostMapping("/cancel")
    public ApiResponse<String> cancel(
    		@Valid
            @RequestBody CancelRequest request,
            @RequestHeader("X-User-Id") Long userId) {

        return new ApiResponse<>(
                true,
                service.cancelToken(request.getTokenId(), request.getReason()),
                null
        );
    }

    // ================= COMPLETE =================

    @PostMapping("/complete/{tokenId}")
    public ApiResponse<String> complete(
            @PathVariable Long tokenId) {

        return new ApiResponse<>(
                true,
                service.completeToken(tokenId),
                null
        );
    }

    // ================= USER DASHBOARD =================

    @GetMapping("/dashboard/user")
    public ApiResponse<UserQueueDashboard> getUserDashboard(
            @RequestParam Long queueId,
            @RequestHeader("X-User-Id") Long userId) {

        return new ApiResponse<>(
                true,
                "User dashboard fetched",
                service.getUserDashboard(userId, queueId)
        );
    }

    // ================= ADMIN DASHBOARD =================

    @GetMapping("/dashboard/queue")
    public ApiResponse<QueueDashboard> getQueueDashboard(
            @RequestParam Long queueId) {

        return new ApiResponse<>(
                true,
                "Queue dashboard fetched",
                service.getQueueDashboard(queueId)
        );
    }

    // ================= NOTIFICATIONS =================

    @GetMapping("/notifications")
    public ApiResponse<List<Notification>> getNotifications(
            @RequestHeader("X-User-Id") Long userId) {

        return new ApiResponse<>(
                true,
                "Notifications fetched",
                notificationService.getUserNotifications(userId)
        );
    }
}